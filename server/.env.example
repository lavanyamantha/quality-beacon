# ============================================================
# QA Dashboard Proxy — Server-Side Credentials
# ============================================================
# These are TRUE server-side secrets — never exposed to browsers.
# Copy this file to .env in the server/ folder.
# ============================================================

# Proxy server port (default: 3001)
# PROXY_PORT=3001

# Azure DevOps
# AZURE_DEVOPS_URL=https://dev.azure.com/your-org/your-project
# AZURE_DEVOPS_TOKEN=your-personal-access-token

# Jira Cloud (token = base64 of email:api-token)
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_TOKEN=your-base64-encoded-credentials

# SonarQube
# SONARQUBE_URL=https://sonarqube.your-company.com
# SONARQUBE_TOKEN=your-sonarqube-token

# GitHub
# GITHUB_URL=https://github.com/your-org/your-repo
# GITHUB_TOKEN=ghp_your-personal-access-token

# GitLab
# GITLAB_URL=https://gitlab.com/your-org/your-project
# GITLAB_TOKEN=glpat-your-personal-access-token

# Jenkins (token = base64 of user:api-token)
# JENKINS_URL=https://jenkins.your-company.com
# JENKINS_TOKEN=your-base64-encoded-credentials

# Bitbucket
# BITBUCKET_URL=https://bitbucket.org/your-workspace/your-repo
# BITBUCKET_TOKEN=your-app-password

# AWS
# AWS_URL=https://console.aws.amazon.com
# AWS_TOKEN=your-access-key

# Selenium Grid
# SELENIUM_URL=https://selenium-grid.your-company.com
# SELENIUM_TOKEN=your-token
