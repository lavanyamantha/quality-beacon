# ============================================================
# QA Dashboard Proxy — Server-Side Credentials
# ============================================================
# These are TRUE server-side secrets — never exposed to browsers.
# Copy this file to .env in the server/ folder.
# ============================================================

# Proxy server port (default: 3001)
# PROXY_PORT=3001

# Public URL of this proxy server (used for OAuth callbacks)
# PROXY_BASE_URL=http://localhost:3001

# Frontend URL (for OAuth redirects back to the app)
# FRONTEND_URL=http://localhost:5173

# ── Authentication ────────────────────────────────────────────

# JWT secret for signing auth tokens (CHANGE THIS IN PRODUCTION!)
# JWT_SECRET=your-strong-random-secret-here

# JWT token expiry (default: 8h)
# JWT_EXPIRY=8h

# Comma-separated list of admin emails (everyone else is viewer)
# ADMIN_EMAILS=admin@company.com,lead@company.com

# ── Microsoft Entra ID (Azure AD) ────────────────────────────
# Register at: Azure Portal → App registrations → New registration
# Redirect URI: {PROXY_BASE_URL}/api/auth/azure-ad/callback
# AZURE_AD_TENANT_ID=your-tenant-id
# AZURE_AD_CLIENT_ID=your-client-id
# AZURE_AD_CLIENT_SECRET=your-client-secret

# ── GitHub OAuth ──────────────────────────────────────────────
# Register at: GitHub → Settings → Developer Settings → OAuth Apps
# Callback URL: {PROXY_BASE_URL}/api/auth/github/callback
# GITHUB_CLIENT_ID=your-github-oauth-client-id
# GITHUB_CLIENT_SECRET=your-github-oauth-client-secret

# ── Google Workspace OAuth ────────────────────────────────────
# Register at: Google Cloud Console → APIs & Services → Credentials
# Authorized redirect URI: {PROXY_BASE_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── AWS IAM Identity Center (SAML) ───────────────────────────
# Configure in AWS SSO → Applications → Add custom SAML app
# ACS URL: {PROXY_BASE_URL}/api/auth/aws-sso/callback
# AWS_SSO_ENTRY_POINT=https://portal.sso.us-east-1.amazonaws.com/saml/assertion/...
# AWS_SSO_ISSUER=qa-dashboard
# AWS_SSO_CERT=MIIDpDCCAoy...  (IdP signing certificate, single-line base64)

# ── Integration Credentials ──────────────────────────────────

# Azure DevOps
# AZURE_DEVOPS_URL=https://dev.azure.com/your-org/your-project
# AZURE_DEVOPS_TOKEN=your-personal-access-token

# Jira Cloud (token = base64 of email:api-token)
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_TOKEN=your-base64-encoded-credentials

# SonarQube
# SONARQUBE_URL=https://sonarqube.your-company.com
# SONARQUBE_TOKEN=your-sonarqube-token

# GitHub (integration — separate from OAuth above)
# GITHUB_URL=https://github.com/your-org/your-repo
# GITHUB_TOKEN=ghp_your-personal-access-token

# GitLab
# GITLAB_URL=https://gitlab.com/your-org/your-project
# GITLAB_TOKEN=glpat-your-personal-access-token

# Jenkins (token = base64 of user:api-token)
# JENKINS_URL=https://jenkins.your-company.com
# JENKINS_TOKEN=your-base64-encoded-credentials

# Bitbucket
# BITBUCKET_URL=https://bitbucket.org/your-workspace/your-repo
# BITBUCKET_TOKEN=your-app-password

# AWS (integration)
# AWS_URL=https://console.aws.amazon.com
# AWS_TOKEN=your-access-key

# Selenium Grid
# SELENIUM_URL=https://selenium-grid.your-company.com
# SELENIUM_TOKEN=your-token
