# ============================================================
# QA Dashboard — Frontend Environment Variables
# ============================================================
# Copy to `.env.local` for local development (gitignored).
#
# RECOMMENDED: Use the proxy server (server/) for production
# so credentials stay server-side. Only set VITE_PROXY_URL here.
# ============================================================

# ── Proxy Mode (RECOMMENDED for production) ──────────────────
# Point to your running proxy server. When set, all API calls
# route through the proxy and no VITE_*_TOKEN vars are needed.
# VITE_PROXY_URL=http://localhost:3001

# ── Direct Mode (dev/demo only — tokens in browser memory) ───
# Only use these if NOT using the proxy server.
#
# VITE_AZURE_DEVOPS_URL=https://dev.azure.com/your-org/your-project
# VITE_AZURE_DEVOPS_TOKEN=your-personal-access-token
# VITE_JIRA_URL=https://your-domain.atlassian.net
# VITE_JIRA_TOKEN=your-api-token
# VITE_SONARQUBE_URL=https://sonarqube.your-company.com
# VITE_SONARQUBE_TOKEN=your-sonarqube-token
# VITE_GITHUB_URL=https://github.com/your-org/your-repo
# VITE_GITHUB_TOKEN=ghp_your-personal-access-token
# VITE_GITLAB_URL=https://gitlab.com/your-org/your-project
# VITE_GITLAB_TOKEN=glpat-your-personal-access-token
# VITE_JENKINS_URL=https://jenkins.your-company.com
# VITE_JENKINS_TOKEN=your-jenkins-api-token
# VITE_BITBUCKET_URL=https://bitbucket.org/your-workspace/your-repo
# VITE_BITBUCKET_TOKEN=your-app-password
# VITE_AWS_URL=https://console.aws.amazon.com
# VITE_AWS_TOKEN=your-access-key-id
# VITE_SELENIUM_URL=https://selenium-grid.your-company.com
# VITE_SELENIUM_TOKEN=your-selenium-token
