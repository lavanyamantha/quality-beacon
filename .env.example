# ============================================================
# QA Dashboard — Integration Credentials
# ============================================================
# Copy this file to `.env` or `.env.local` and fill in values
# for the integrations you use. All variables are optional.
# The app falls back to demo data for unconfigured sources.
# ============================================================

# Azure DevOps
# VITE_AZURE_DEVOPS_URL=https://dev.azure.com/your-org/your-project
# VITE_AZURE_DEVOPS_TOKEN=

# Jira Cloud
# VITE_JIRA_URL=https://your-domain.atlassian.net
# VITE_JIRA_TOKEN=

# SonarQube
# VITE_SONARQUBE_URL=https://sonarqube.your-company.com
# VITE_SONARQUBE_TOKEN=

# GitHub
# VITE_GITHUB_URL=https://github.com/your-org/your-repo
# VITE_GITHUB_TOKEN=ghp_...

# GitLab
# VITE_GITLAB_URL=https://gitlab.com/your-org/your-project
# VITE_GITLAB_TOKEN=glpat-...

# Jenkins
# VITE_JENKINS_URL=https://jenkins.your-company.com
# VITE_JENKINS_TOKEN=

# Bitbucket
# VITE_BITBUCKET_URL=https://bitbucket.org/your-workspace/your-repo
# VITE_BITBUCKET_TOKEN=

# AWS (CodePipeline / CodeBuild)
# VITE_AWS_URL=https://console.aws.amazon.com
# VITE_AWS_TOKEN=

# Selenium Grid
# VITE_SELENIUM_URL=https://selenium-grid.your-company.com
# VITE_SELENIUM_TOKEN=
